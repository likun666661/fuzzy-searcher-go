# Copy to .env and adjust paths for local service runs.
#
# scripts/run_service_local.sh loads .env by default. scripts/run_service_smoke.sh
# is self-contained and does not require these paths.

YOUTU_RAG_PROFILE=demo
YOUTU_RAG_HTTP_ADDR=:8080
YOUTU_RAG_ARTIFACT_ROOT=../youtu-graphrag
YOUTU_RAG_DATASET=demo
YOUTU_RAG_GRAPH=../youtu-graphrag/output/graphs/demo_new.json
YOUTU_RAG_CHUNKS=../youtu-graphrag/output/chunks/demo.txt
YOUTU_RAG_MODE=native-path1-rerank
YOUTU_RAG_SIDECAR_URL=http://127.0.0.1:8765

# Use strict startup validation in demo/production runs.
YOUTU_RAG_VALIDATE_ON_START=true

# Python worker defaults normally resolve under YOUTU_RAG_ARTIFACT_ROOT.
# Override when workers live elsewhere.
# YOUTU_RAG_WORKER_CWD=/abs/path/youtu-graphrag
# YOUTU_RAG_PYTHON=/abs/path/youtu-graphrag/.venv/bin/python
# YOUTU_RAG_PARSE_DOCUMENTS_SCRIPT=/abs/path/youtu-graphrag/scripts/parse_documents_worker.py
# YOUTU_RAG_BUILD_GRAPH_SCRIPT=/abs/path/youtu-graphrag/scripts/build_graph_worker.py
# YOUTU_RAG_ANSWER_SCRIPT=/abs/path/youtu-graphrag/scripts/answer_worker.py
# YOUTU_RAG_GOLDEN_SCRIPT=/abs/path/youtu-graphrag/scripts/generate_retriever_golden.py
